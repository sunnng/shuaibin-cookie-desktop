{
  "name": "server",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/start.ts --outfile server",
    "dev": "tsx watch src/start.ts",
    "start": "node dist/start.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@shuaibin-cookie-app/db": "workspace:*",
    "@shuaibin-cookie-app/env": "workspace:*",
    "dotenv": "catalog:",
    "hono": "^4.8.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@shuaibin-cookie-app/config": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "^0.21.9",
    "tsx": "^4.19.2",
    "typescript": "catalog:"
  }
}
